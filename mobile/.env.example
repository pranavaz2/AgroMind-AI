# ─────────────────────────────────────────────────────────
# React Native Expo Environment Configuration
# ─────────────────────────────────────────────────────────
# This is a template file. DO NOT commit your actual .env
# file to version control. Copy this to .env and fill in values.

# API Configuration
# Use your computer's local IP address (e.g., 192.168.1.x) when testing on a physical device via Expo Go.
# Do NOT use localhost or 127.0.0.1 for mobile physical devices.
EXPO_PUBLIC_API_URL=http://192.168.1.100:5000/api/v1

# Other variables (Feature flags, Analytics keys, etc.)
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=false
