APP_NAME="AgroMind AI Prediction Service"
APP_ENV=development
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# TensorFlow model path. Can be a SavedModel directory or .keras/.h5 file.
AI_MODEL_PATH=models/leaf_disease_model.keras
AI_CLASS_NAMES_PATH=models/class_names.json

# Fallback comma-separated labels in the same order as your model output neurons.
# If AI_CLASS_NAMES_PATH exists, the service reads labels from that JSON file.
AI_CLASS_NAMES=Healthy,Early Blight,Late Blight,Leaf Spot,Rust

# Input shape expected by the model.
IMAGE_SIZE=224

# Development fallback lets the endpoint return a safe demo prediction
# when no TensorFlow model file exists yet. Set false in production.
ENABLE_DEMO_FALLBACK=true
