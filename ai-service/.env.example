# ─────────────────────────────────────────────────────────
# AI Microservice Environment Configuration
# ─────────────────────────────────────────────────────────
# This is a template file. DO NOT commit your actual .env
# file to version control. Copy this to .env and fill in values.

# Server Setup
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Model Configuration
# Path to the fine-tuned MobileNetV2 .keras file
MODEL_PATH=models/plant_disease_model.keras

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5000,http://localhost:3000

# Performance
# Number of Uvicorn workers
WORKERS=1
